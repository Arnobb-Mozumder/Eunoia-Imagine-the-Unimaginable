# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/gameserver?retryWrites=true&w=majority

# Firebase Admin SDK (from service account key JSON)
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY_ID=your-key-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_CERT_URL=your-cert-url

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
VERCEL_FRONTEND_URL=https://your-deployed-frontend.com

# API Port
PORT=3001

# Environment
NODE_ENV=development
